# Faultline environment template (impl plan §14). Copy to repo root as `.env` and fill in.
# NEVER commit `.env` — it is gitignored. Production values live in Secret Manager.

# ── Google Cloud ─────────────────────────────────────────────
GCP_PROJECT=
VERTEX_LOCATION=us-central1
GCS_BUCKET=               # e.g. <project>-faultline (no gs:// prefix)
BQ_DATASET=faultline

# ── Models (pinned — see impl plan §5; confirm in Model Garden at kickoff) ──
GEMINI_MODEL_PRO=gemini-3.1-pro
GEMINI_MODEL_FLASH=gemini-3.5-flash
# E's spike (2026-06-10): gemini-3.1-flash-live-preview is AI-Studio-only, NOT on Vertex.
# Ship on 2.5 native-audio; flip this one line when 3.1 lands on Vertex.
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
GEMINI_LIVE_MODEL_FALLBACK=gemini-live-2.5-flash-native-audio

# ── Elastic ──────────────────────────────────────────────────
KIBANA_URL=               # https://<deployment>.kb.<region>.gcp.elastic-cloud.com
ELASTIC_API_KEY=          # MUST carry Kibana Agent Builder privileges (see PROVISIONING.md)
ELASTIC_MODE=mock         # mock | live — the only switch between fixtures and the real cluster
ELASTIC_EVENTS_INDEX=world-events   # Session D uses world-events-dev until sync S1
ELASTICSEARCH_URL=        # https://<deployment>.es.<region>.gcp.elastic-cloud.com — direct ES writes
                          # (what-if synthetic events from agents/, feed_ingest bulk writes); reuses ELASTIC_API_KEY

# ── Maps ─────────────────────────────────────────────────────
MAPS_API_KEY=

# ── Runtime ──────────────────────────────────────────────────
COMPANY_PROFILE=company_profile.json   # swap to company_profile.pharma.json for the pharma beat
WS_URL=ws://localhost:8080/ws
API_BASE=http://localhost:8080
VOICE_GATEWAY_URL=ws://localhost:8082

# ── Frontend mirrors (Vite exposes only VITE_*) ──────────────
VITE_WS_URL=ws://localhost:8080/ws
VITE_API_BASE=http://localhost:8080
VITE_VOICE_WS_URL=ws://localhost:8082
VITE_MAPS_API_KEY=
VITE_DEMO_MODE=replay     # replay | live — replay drives the UI from contracts/fixtures/ws_replay.jsonl
